-- mysql
UPDATE clubs
SET location = ST_SRID(POINT(lon, lat), 4326)
WHERE lat <> 0
AND lon <> 0;

-- mariadb
UPDATE clubs
SET location = ST_GeomFromText(CONCAT('POINT(', lon, ' ', lat, ')'), 4326)
WHERE lat <> 0
  AND lon <> 0;

